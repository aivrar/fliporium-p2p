[Unit]
Description=Fliporium public stats server
Documentation=https://fliporium.com
After=network-online.target headscale.service
Wants=network-online.target

[Service]
Type=simple
# Runs as root so it can exec the headscale CLI which needs the sqlite at
# /var/lib/headscale. Headscale itself runs as root on this box so this is
# consistent with the rest of the stack.
User=root
# SMTP relay credentials (Gmail app password etc.) live in this root-only
# file, kept out of the unit so they don't show in `systemctl cat`. The
# leading "-" makes it optional: flipstats runs fine without it, just
# skipping the contact-email relay.
EnvironmentFile=-/etc/flipstats/smtp.env
ExecStart=/usr/local/bin/flipstats \
  -listen 127.0.0.1:8088 \
  -data /var/lib/flipstats \
  -exe /var/www/fliporium/dl/fliporium.exe \
  -headscale /usr/bin/headscale \
  -headscale-cfg /etc/headscale/config.yaml
Restart=on-failure
RestartSec=3
NoNewPrivileges=true
ProtectSystem=full
ProtectHome=true
PrivateTmp=true
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
