# Credentials and one-shot test artifacts — never commit these
.vps
.ssh-askpass.cmd
.preauth-test
.fix-log.txt

# Temp scripts used during setup; kept locally for reference but not history
.tmp-*.sh
.headscale-config-default.yaml

# Build output
*.exe
*.exe~
*.dll
# Bare-name binary fallbacks (anchored to repo root so we don't ignore
# the cmd/fliporium/ source dir!).
/fliporium-test
/fliporium
/fliporium-cli

# Test assets
test-image.png
screenshot-*.png

# Per-node tailscale identity / data folder (each install is its own)
fliporium-data/
fliporium-data-*/
flip-*-data/
node-*/

# Go build cache leftovers
vendor/
*.test
*.out
coverage.out

# IDE
.vscode/
.idea/
*.swp

# Stray captured streams from debugging
stdout.log
stderr.log
